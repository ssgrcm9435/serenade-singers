model WaitingRoomParticipant {
  id          String   @id @default(cuid())
  meetingId   String
  memberId    String?
  fullName    String
  socketId    String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [meetingId])

  @@index([meetingId])
}
